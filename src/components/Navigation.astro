---
const navItems = [
  { href: "/index", label: "HOME" },
  { href: "/projects", label: "PROJECTS" },
  { href: "/writing", label: "DOCUMENTATION" },
  { href: "/contact", label: "CONTACT" },
];

const currentPath = Astro.url.pathname;
---

<nav class="engineering-nav" id="mainNav">
  <div class="nav-container">
    <!-- ANUJ KHATRI Title - Only visible when scrolled -->
    <div class="nav-title">&lt; ANUJ KHATRI /&gt;</div>
    
    <!-- Navigation Links -->
    <div class="nav-links">
      {
        navItems.map((item) => {
          const isActive = currentPath === item.href || (currentPath.startsWith(item.href) && item.href !== '/index');
          return (
            <a
              href={item.href}
              class={`nav-link ${isActive ? 'active' : ''}`}
            >
              <span class="nav-label">{item.label}</span>
              {isActive && <span class="nav-indicator"></span>}
            </a>
          );
        })
      }
    </div>
  </div>
</nav>

<script>
  const nav = document.getElementById('mainNav');
  const isHomePage = window.location.pathname === '/' || window.location.pathname === '/index';
  
  function handleScroll() {
    if (isHomePage) {
      if (window.scrollY > 50) {
        nav.classList.add('scrolled');
      } else {
        nav.classList.remove('scrolled');
      }
    } else {
      // Always show scrolled state on other pages
      nav.classList.add('scrolled');
    }
  }
  
  // Initial check
  handleScroll();
  
  // Listen for scroll events
  window.addEventListener('scroll', handleScroll, { passive: true });
</script>

<style>
  .engineering-nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 999;
    background: transparent;
    backdrop-filter: none;
    transition: all 0.3s ease;
  }
  
  .engineering-nav.scrolled {
    background: var(--bg-card);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border-color);
  }
  
  .nav-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 40px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    height: 48px;
  }
  
  .nav-title {
    font-family: var(--drawing-font);
    font-size: 14px;
    color: var(--schematic-blue);
    letter-spacing: 0.05em;
    opacity: 0;
    transform: translateY(-10px);
    transition: all 0.3s ease;
    pointer-events: none;
  }
  
  .engineering-nav.scrolled .nav-title {
    opacity: 1;
    transform: translateY(0);
  }
  
  .nav-links {
    display: flex;
    gap: 4px;
  }
  
  .nav-link {
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 12px;
    text-decoration: none;
    font-family: var(--drawing-font);
    font-size: 10px;
    letter-spacing: 0.08em;
    color: var(--text-secondary);
    transition: all 0.2s ease;
  }
  
  .nav-link:hover {
    color: var(--text-primary);
  }
  
  .nav-link.active {
    color: var(--schematic-blue);
  }
  
  .nav-label {
    text-transform: uppercase;
  }
  
  .nav-indicator {
    position: absolute;
    bottom: -8px;
    left: 50%;
    transform: translateX(-50%);
    width: 4px;
    height: 4px;
    background: var(--schematic-blue);
    border-radius: 50%;
  }
  
  /* Mobile responsive */
  @media (max-width: 768px) {
    .nav-container {
      padding: 0 20px;
    }
    
    .nav-link {
      padding: 6px 10px;
      font-size: 9px;
    }
    
    .nav-title {
      font-size: 12px;
    }
  }
</style>
