---
import BaseLayout from "../layouts/BaseLayout.astro";
import DrawingSheet from "../components/DrawingSheet.astro";
import SchematicPhoto from "../components/SchematicPhoto.astro";
---

<BaseLayout>
  <DrawingSheet>
    <section class="hero-grid">
      <!-- LEFT -->

      <div class="flex flex-col gap-6 max-w-xl">
        <h1 class="text-6xl text-blue-700">&lt; ANUJ KHATRI/&gt;</h1>

        <div class="hero-content">
          <p>&gt; Hello World!</p>

          <p>&gt; I am a wanna-be polymath.</p>

          <p>
            &gt; I build things with code, circuits, and whatever I can find.
          </p>
        </div>

        <div class="space-y-4">
          <p class="font-mono text-blue-700">user /socials</p>

          <div
            class="flex flex-wrap gap-x-6 gap-y-2 font-mono text-sm uppercase tracking-wide"
          >
            <a
              href="https://github.com/yourusername"
              class="text-blue-700 hover:text-blue-900 transition-colors"
              >▸ GITHUB</a
            >
            <a
              href="https://linkedin.com/in/yourprofile"
              class="text-blue-700 hover:text-blue-900 transition-colors"
              >▸ LINKEDIN</a
            >
            <a
              href="https://instagram.com/yourprofile"
              class="text-blue-700 hover:text-blue-900 transition-colors"
              >▸ INSTAGRAM</a
            >
            <a
              href="/resume.pdf"
              class="crosshair-mask text-blue-700 hover:text-blue-900 transition-colors"
              >▸ RESUME</a
            >
          </div>
        </div>
      </div>

      <!-- RIGHT -->

      <div>
        <SchematicPhoto
          src="/profilepic.jpg"
          alt="Anuj Khatri"
          designator="U1"
          category="HUMAN"
          name="ANUJ KHATRI"
          status="ACTIVE"
          specialty="SOFTWARE SYSTEMS"
          revision="2.0"
        />
      </div>
    </section>
  </DrawingSheet>
</BaseLayout>
