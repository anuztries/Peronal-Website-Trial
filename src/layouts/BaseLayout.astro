---
import "../styles/global.css";
import Crosshair from "../components/Crosshair.jsx";
import Footer from "../components/Footer.astro";
import ThemeToggle from "../components/ThemeToggle.astro";
import Navigation from "../components/Navigation.astro";

const { title = "Anuj Khatri | Hardware Engineer", showNav = true } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content="Computer/Electronics Hardware Engineer portfolio - PCB design, embedded systems, FPGA development" />
    <title>{title}</title>
  </head>
  <body>
    <ThemeToggle client:load />
    {showNav && <Navigation />}
    <Crosshair client:load />
    <slot />
    <Footer />
  </body>
</html>

<style>
  body {
    margin: 0;
    width: 100%;
    padding-top: 48px; /* Account for fixed nav bar height */
  }
</style>
