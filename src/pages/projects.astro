---
import BaseLayout from "../layouts/BaseLayout.astro";
import ProjectCard from "../components/ProjectCard.astro";
import { getCollection } from "astro:content";

const allProjects = await getCollection("projects");

const publishedProjects = allProjects
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout title="PROJECTS | Anuj Khatri">
  <div class="page-container">
    <!-- Page Header -->
    <div class="page-header">
      <div class="title-block">
        <span class="page-designator">DWG-001</span>
        <h1 class="page-title">ENGINEERING PROJECTS</h1>
        <p class="page-subtitle">A collection of hardware and embedded systems designs</p>
      </div>
      
      <div class="specs-block">
        <div class="spec-item">
          <span class="spec-label">TOTAL PROJECTS:</span>
          <span class="spec-value">{publishedProjects.length}</span>
        </div>
        <div class="spec-item">
          <span class="spec-label">LATEST REV:</span>
          <span class="spec-value">{publishedProjects[0]?.data?.date ? new Date(publishedProjects[0].data.date).toLocaleDateString() : 'N/A'}</span>
        </div>
      </div>
    </div>
    
    <!-- Projects Grid -->
    <div class="projects-full-grid">
      {
        publishedProjects.map((project, index) => (
          <ProjectCard
            title={project.data.title}
            description={project.data.description}
            date={project.data.date}
            tech={project.data.tech}
            url={`/projects/${project.id}`}
            designator={`PRJ-${String(index + 1).padStart(3, '0')}`}
          />
        ))
      }
    </div>
    
    {
      publishedProjects.length === 0 && (
        <div class="empty-state">
          <svg class="empty-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
            <rect x="3" y="3" width="18" height="18" rx="2"/>
            <path d="M9 9h6M9 13h6M9 17h4"/>
          </svg>
          <p class="empty-text">[ NO PROJECTS LOADED ]</p>
          <p class="empty-subtext">Check back soon for new designs</p>
        </div>
      )
    }
    
    <!-- Back to home -->
    <div class="back-link-container">
      <a href="/" class="back-link">[RETURN TO HOME]</a>
    </div>
  </div>
</BaseLayout>

<style>
  .page-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 40px 20px;
  }
  
  .page-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 60px;
    padding-bottom: 30px;
    border-bottom: 2px solid var(--border-color);
  }
  
  .title-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  
  .page-designator {
    font-family: var(--drawing-font);
    font-size: 10px;
    color: var(--text-secondary);
    letter-spacing: 0.15em;
  }
  
  .page-title {
    font-family: var(--drawing-font);
    font-size: 32px;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0;
    letter-spacing: 0.05em;
  }
  
  .page-subtitle {
    font-family: "Inter", sans-serif;
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0;
    max-width: 500px;
    line-height: 1.6;
  }
  
  .specs-block {
    display: flex;
    flex-direction: column;
    gap: 12px;
    padding: 16px 20px;
    background: rgba(125, 125, 125, 0.03);
    border: 1px solid var(--border-color);
  }
  
  .spec-item {
    display: flex;
    gap: 12px;
    align-items: center;
  }
  
  .spec-label {
    font-family: var(--drawing-font);
    font-size: 9px;
    color: var(--text-secondary);
    letter-spacing: 0.08em;
  }
  
  .spec-value {
    font-family: var(--drawing-font);
    font-size: 11px;
    color: var(--text-primary);
    font-weight: 600;
  }
  
  .projects-full-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 28px;
    margin-bottom: 60px;
  }
  
  .empty-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 80px 20px;
    text-align: center;
  }
  
  .empty-icon {
    width: 64px;
    height: 64px;
    color: var(--text-secondary);
    opacity: 0.5;
    margin-bottom: 20px;
  }
  
  .empty-text {
    font-family: var(--drawing-font);
    font-size: 14px;
    color: var(--text-secondary);
    margin: 0 0 8px 0;
    letter-spacing: 0.05em;
  }
  
  .empty-subtext {
    font-family: "Inter", sans-serif;
    font-size: 13px;
    color: var(--text-secondary);
    margin: 0;
    opacity: 0.7;
  }
  
  .back-link-container {
    padding-top: 40px;
    border-top: 1px dashed var(--border-color);
  }
  
  .back-link {
    font-family: var(--drawing-font);
    font-size: 11px;
    color: var(--drawing-red);
    text-decoration: none;
    letter-spacing: 0.05em;
    transition: color 0.2s ease;
  }
  
  .back-link:hover {
    color: var(--drawing-red-light);
  }
  
  @media (max-width: 768px) {
    .page-header {
      flex-direction: column;
      gap: 30px;
    }
    
    .page-title {
      font-size: 24px;
    }
    
    .projects-full-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
