---
interface Props {
  src: string;
  alt?: string;

  eyebrow?: string;
  designator?: string;
  category?: string;

  name?: string;
  status?: string;
  specialty?: string;
  revision?: string;
}

const {
  src,
  alt = "",

  eyebrow = "[THIS IS ME]",
  designator = "U1",
  category = "HUMAN",

  name = "ANUJ KHATRI",
  status = "ACTIVE",
  specialty = "SOFTWARE SYSTEMS",
  revision = "2.0",
} = Astro.props;
---

<div class="schematic-photo hero-photo">
  <div class="photo-wrapper">
    <!-- Centered eyebrow text above photo -->
    <p class="eyebrow-centered">{eyebrow}</p>

    <div class="photo-container">
      <span class="corner tl"></span>
      <span class="corner tr"></span>
      <span class="corner bl"></span>
      <span class="corner br"></span>
      <!-- Category tag positioned on top-right corner of border -->
      <span class="category-tag-overlay">{category}</span>
      <img class="photo" src={src} alt={alt} />
    </div>
  </div>

  <!-- Property Table -->
  <div class="properties">
    <div>
      <span>IDENTIFIER</span>
      <span class="separator"></span>
      <span>{name}</span>
    </div>

    <div>
      <span>STATUS</span>
      <span class="separator"></span>
      <span>{status}</span>
    </div>

    <div>
      <span>SPECIALTY</span>
      <span class="separator"></span>
      <span>{specialty}</span>
    </div>

    <div>
      <span>REVISION</span>
      <span class="separator"></span>
      <span>{revision}</span>
    </div>
  </div>
</div>

<style>
  .schematic-photo {
    width: fit-content;
    display: flex;
    flex-direction: column;
    gap: 10px;
    color: rgb(29, 78, 216);
    font-family: "IBM Plex Mono", monospace;
  }

  .photo-wrapper {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  /* Centered eyebrow text above photo - no box, just text */
  .eyebrow-centered {
    margin: 0 0 8px 0;
    font-size: 12px;
    letter-spacing: 0.05em;
    text-align: center;
    font-weight: normal;
  }

  .schematic-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    font-size: 11px;
    letter-spacing: 0.05em;
  }

  .schematic-header .reference {
    font-weight: 600;
  }

  .category-tag {
    border: 1px solid currentColor;
    padding: 1px 8px;
    text-transform: uppercase;
    font-size: 10px;
  }

  /* Category tag overlay positioned on top-right corner of photo border */
  .category-tag-overlay {
    position: absolute;
    top: -10px;
    right: 20px;
    background: white;
    border: 1px solid rgb(29, 78, 216);
    padding: 1px 8px;
    text-transform: uppercase;
    font-size: 10px;
    letter-spacing: 0.05em;
    z-index: 10;
  }

  .photo-container {
    position: relative;
    width: fit-content;
    border: 1.5px solid rgb(29, 78, 216);
    padding: 8px;
    background: white;
  }

  .photo {
    display: block;
    width: 260px;
    height: 330px;
    object-fit: cover;
    object-position: top;
  }

  .corner {
    position: absolute;
    width: 10px;
    height: 10px;
    border-color: rgb(29, 78, 216);
  }

  .corner.tl {
    top: -1px;
    left: -1px;
    border-top: 2px solid;
    border-left: 2px solid;
  }

  .corner.tr {
    top: -1px;
    right: -1px;
    border-top: 2px solid;
    border-right: 2px solid;
  }

  .corner.bl {
    bottom: -1px;
    left: -1px;
    border-bottom: 2px solid;
    border-left: 2px solid;
  }

  .corner.br {
    bottom: -1px;
    right: -1px;
    border-bottom: 2px solid;
    border-right: 2px solid;
  }

  .properties {
    display: flex;
    flex-direction: column;
    border: 1px solid rgb(29, 78, 216);
    letter-spacing: 0.03em;
  }

  .properties div {
    display: grid;
    grid-template-columns: 120px auto 1fr;
    border-bottom: 1px solid rgb(29, 78, 216);
    padding: 4px 8px;
    font-size: 12px;
    align-items: center;
  }

  .properties div:last-child {
    border-bottom: none;
  }

  .properties span:first-child {
    font-weight: 600;
  }

  /* Separator line between key and value */
  .separator {
    border-left: 1px solid rgb(29, 78, 216);
    height: 14px;
    margin: 0 12px;
  }
</style>
