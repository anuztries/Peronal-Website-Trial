```gitignore
# Build artifacts
dist/
build/
*.js
*.css
*.map

# Dependencies
node_modules/

# Environment variables
.env
.env.local
*.env.*

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# OS generated files
.DS_Store
Thumbs.db

# Coverage reports
coverage/
htmlcov/
.coverage

# Python specific
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.so
*.egg-info/
.eggs/
.venv/
venv/
.mypy_cache/
.pytest_cache/
.tox/

# Node.js specific
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Java specific
*.class
*.jar
*.war
*.ear
target/
.gradle/

# C/C++ specific
*.o
*.a
*.obj
*.out
*.exe
*.dll
*.so

# Go specific
*.exe
*.test
*.prof
vendor/

# Temporary files
*.tmp
*.temp
*.log
*~
.DS_Store
Thumbs.db
```

